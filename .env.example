MONGODB_URI=mongodb://127.0.0.1:27017/job_crawler
LINK_VALIDATION_TTL_MINUTES=360
# Optional comma-separated additions merged into the built-in Greenhouse registry.
# Example: GREENHOUSE_BOARD_REGISTRY_APPEND=airbyte,checkr,loom
GREENHOUSE_BOARD_REGISTRY_APPEND=
# Legacy alias for extra Greenhouse tokens. Still supported, but prefer GREENHOUSE_BOARD_REGISTRY_APPEND.
GREENHOUSE_BOARD_TOKENS=
LEVER_SITE_TOKENS=figma,plaid,robinhood
ASHBY_BOARD_TOKENS=notion,ramp,replit
PUBLIC_SEARCH_DISCOVERY_ENABLED=true
PUBLIC_SEARCH_DISCOVERY_MAX_RESULTS=8
# Optional JSON array. Example:
# COMPANY_PAGE_SOURCE_CONFIG=[{"type":"json_feed","company":"Example","url":"https://example.com/jobs.json"},{"type":"json_ld_page","company":"Another","url":"https://another.com/careers"},{"type":"html_page","company":"PublicCo","url":"https://publicco.com/careers"}]
COMPANY_PAGE_SOURCE_CONFIG=
